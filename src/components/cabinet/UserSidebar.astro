---
import { PATHS } from '@/configs/paths'
import type { ProfileResponseData } from '@/lib/api'

type Props = {
	id: ProfileResponseData['id']
	firstName?: ProfileResponseData['name']
	lastName?: ProfileResponseData['lastName']
	email: ProfileResponseData['email']
	avatarUrl?: ProfileResponseData['photo']
}

const { id, firstName, lastName, email, avatarUrl = null } = Astro.props as Props
---

<aside class='flex flex-col gap-[20px] rounded-[20px] border border-black/10 bg-white/60 p-[20px] shadow-[0_12px_40px_rgba(20,28,64,0.06)] sm:flex-row sm:items-start xl:sticky xl:top-[120px] xl:flex-col'>
	{
		avatarUrl ? (
			<img
				src={avatarUrl}
				alt={`${lastName} ${firstName}`}
				class='h-[150px] w-[150px] shrink-0 rounded-[30px] object-cover'
			/>
		) : (
			<div class='h-[150px] w-[150px] shrink-0 rounded-[30px] bg-black/8' />
		)
	}

	<div class='flex min-w-0 flex-1 flex-col gap-[10px] text-[#152551]'>
		<div class='text-[22px] leading-[29px] font-medium'>
			<div>{lastName || firstName}</div>
			<div>{lastName ? firstName : ''}</div>
		</div>

		<a
			href={`mailto:${email}`}
			class='w-fit text-[18px] leading-[24px] underline underline-offset-[4px] transition-opacity hover:opacity-70'
		>
			{email}
		</a>

		<div class='text-[18px] leading-[24px]'>ID: {id}</div>

		<a
			href={PATHS.auth.logout}
			class='mt-[22px] w-fit text-[14px] leading-[18px] font-medium text-link'
		>
			Выйти
		</a>
	</div>
</aside>
