---
import RegularMenu from '@/components/shared/topMenu/RegularMenu.astro'
import Layout from '@/layouts/Layout.astro'
import { NewPasswordForm } from '@/components/auth/newPasswordForm/NewPasswordForm'
---

<Layout noindex={true}>
	<section class='content flex flex-col'>
		<RegularMenu type='lightBg' />
		<div class='inner-content grid grid-cols-1 min-[1000px]:grid-cols-2 items-start justify-start gap-y-[60px]'>
			<div class='flex flex-col justify-start'>
				<h1>Создание<br />нового пароля</h1>
				<div class='max-w-[600px] mt-[10px]'>Создайте новый пароль для входа в кабинет</div>
			</div>
			<div>
				<NewPasswordForm client:load />
			</div>
		</div>
	</section>
</Layout>
