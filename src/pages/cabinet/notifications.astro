---
import CabinetMenu from '@/components/shared/topMenu/CabinetMenu.astro'
import Layout from '@/layouts/Layout.astro'
import CabinetLeft from '@/components/shared/cabinetLeft/CabinetLeft'

---

<Layout noindex={true}>
	<section class='content flex flex-col'>
		<CabinetMenu type="lightBg" />

		<div class="flex lg:pt-18 pt-4 -mb-20">
			<CabinetLeft/>
			<div class="flex-1 -mx-2.5 px-2.5 lg:px-5 lg:-mx-5 overflow-hidden md:overflow-visible">
				<div class={'flex flex-col mb-12 lg:mb-25 text-text-base w-full'}>
					<div class={'text-[22px] lg:text-[32px] mb-2 lg:mb-1 font-medium text-accent'}>Уведомления</div>
					<div class="lg:grid no-scrollbar  -mx-2.5 px-2.5 lg:gap-10 gap-2.5 w-full flex lg:grid-cols-3 overflow-auto">
						123
					</div>
				</div>

			</div>
		</div>
	</section>
</Layout>


