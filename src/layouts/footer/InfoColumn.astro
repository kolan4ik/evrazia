---
import { cn } from '@/lib/utils'
---

<div class='flex flex-col-reverse min-[1150px]:flex-col justify-between'>
	<div
		class={cn(
			'flex flex-col justify-start gap-[20px] min-[1150px]:gap-[30px]',
			'text-white-text text-[10px]',
			'min-[1150px]:text-[14px]',
		)}
	>
		<div class='flex flex-col gap-0'>
			<div>Орг. комитет:</div>
			<a
				href='mailto:org@premiyaevrazia.su'
				class={cn('text-link-reverse text-[16px]', 'max-[1150px]:text-[18px]', 'max-[700px]:text-[14px]')}
				>org@premiyaevrazia.su</a
			>
		</div>
		<div class='flex flex-col gap-0'>
			<div>Тех. поддержка:</div>
			<a
				href='mailto:support@premiyaevrazia.su'
				class={cn('text-link-reverse text-[16px]', 'max-[1150px]:text-[18px]', 'max-[700px]:text-[14px]')}
				>support@premiyaevrazia.su</a
			>
		</div>
	</div>
</div>
