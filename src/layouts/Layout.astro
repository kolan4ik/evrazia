---
import '../styles/global.css'
import Footer from './footer/Footer.astro'
import CookieAlert from '@/components/shared/cookie/CookieAlert'

type Props = {
	noindex?: boolean
}
const { noindex } = Astro.props as Props
---

<!doctype html>
<html lang='ru'>
	<head>
		<meta charset='UTF-8' />
		<meta
			name='viewport'
			content='width=device-width'
		/>
		{
			noindex && (
				<meta
					name='robots'
					content='noindex, nofollow'
				/>
			)
		}
		<meta
			name='generator'
			content={Astro.generator}
		/>
		<link
			rel='preload'
			href='/fonts/TT%20Firs%20Neue%20Trial%20Var%20Roman.ttf'
			as='font'
			type='font/ttf'
			crossorigin='anonymous'
		/>
		<link
			rel='preload'
			href='/fonts/NyghtSerif-Light.woff2'
			as='font'
			type='font/woff2'
			crossorigin='anonymous'
		/>

		<title>ЕВРАЗИЯ - Международная премия 2026</title>
	</head>
	<body>
		<slot />
		<Footer />
		<CookieAlert client:load />
	</body>
</html>
